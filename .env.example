# PostgreSQL
POSTGRES_PASSWORD=ledger

# Backend
DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger?sslmode=disable
HTTP_PORT=8080

# Deployment environment ("dev" or "production"). Production requires
# CORS_ALLOWED_ORIGIN to be set explicitly — the service will refuse to boot
# without it to avoid shipping a wildcard CORS policy.
ENV=dev

# Comma-separated list of allowed bearer-token API keys for mutating
# endpoints (POST/PUT/PATCH/DELETE). Required in production; without keys,
# all writes pass through unauthenticated.
API_KEYS=dev-key-1,dev-key-2

# CORS allowed origin. Use a single concrete origin in production, e.g.
# https://app.example.com. Only "dev" mode permits this to be empty (falls
# back to "*" without credentials).
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Maximum inbound request body size in bytes. Default 256 KB.
MAX_BODY_BYTES=262144

# HMAC signing key used by the EVM channel webhook adapter to verify
# inbound block-scanner callbacks. Must be at least 32 bytes of entropy in
# production.
EVM_WEBHOOK_SECRET=change-me-min-32-bytes

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
