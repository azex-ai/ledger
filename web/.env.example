# All server-only. The browser never holds ledger credentials: page requests
# are gated by the dashboard session (DASHBOARD_PASSWORD) and API calls go
# through the same-origin BFF proxy, which attaches LEDGER_API_KEY.
LEDGER_API_URL_INTERNAL=http://localhost:8080
LEDGER_API_KEY=
# Operator password for the dashboard login (required in production).
DASHBOARD_PASSWORD=
# Optional: explicit HMAC key for session cookies (derived from the
# password when unset).
DASHBOARD_SESSION_SECRET=
