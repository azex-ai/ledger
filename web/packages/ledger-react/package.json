{
  "name": "@azex/ledger-react",
  "version": "0.5.1",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/charts.d.ts",
      "default": "./dist/charts.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "default": "./dist/headless.js"
    },
    "./wallet/headless": {
      "types": "./dist/wallet-headless.d.ts",
      "default": "./dist/wallet-headless.js"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "default": "./dist/wallet.js"
    },
    "./wallet/heroui": {
      "types": "./dist/wallet-heroui.d.ts",
      "default": "./dist/wallet-heroui.js"
    },
    "./heroui": {
      "types": "./dist/heroui.d.ts",
      "default": "./dist/heroui.js"
    },
    "./styles.css": "./dist/styles.css",
    "./heroui.css": "./dist/heroui.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "codegen": "openapi-typescript ../../../docs/openapi.yaml -o src/client/schema.ts",
    "codegen:check": "npm run codegen && git diff --exit-code src/client/schema.ts"
  },
  "peerDependencies": {
    "@heroui/react": "^3.2.0",
    "@tanstack/react-query": "^5",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "@heroui/react": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "qrcode.react": "^4.2.0",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.55.1"
  },
  "devDependencies": {
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "jsdom": "^29",
    "msw": "^2.15.0",
    "openapi-typescript": "^7",
    "postcss": "^8.5.18",
    "tailwindcss": "^4",
    "tsup": "^8",
    "typescript": "^7",
    "vitest": "^4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
