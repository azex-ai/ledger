{
  "name": "@azex/ledger-react",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": ["*.css"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./charts": { "types": "./dist/charts.d.ts", "default": "./dist/charts.js" },
    "./server": { "types": "./dist/server.d.ts", "default": "./dist/server.js" },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "codegen": "openapi-typescript ../../../docs/openapi.yaml -o src/client/schema.ts",
    "codegen:check": "npm run codegen && git diff --exit-code src/client/schema.ts"
  },
  "peerDependencies": { "react": "^19", "react-dom": "^19", "@tanstack/react-query": "^5" },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "tailwind-merge": "^3.6.0",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "tsup": "^8", "vitest": "^4", "msw": "^2.14.6", "openapi-typescript": "^7",
    "@testing-library/react": "^16", "@testing-library/jest-dom": "^6",
    "jsdom": "^25", "typescript": "^6",
    "@tailwindcss/postcss": "^4", "tailwindcss": "^4", "postcss": "^8"
  },
  "publishConfig": { "registry": "https://registry.npmjs.org", "access": "public" }
}
